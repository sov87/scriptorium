# -------------------------
# SCRIPTORIUM .gitignore
# -------------------------

# Virtual environments
.venv/
venv/
ENV/
env/

# Python caches / build artifacts
__pycache__/
*.py[cod]
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
dist/
build/
*.egg-info/
src/scriptorium.egg-info/

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
*.tmp

# -------------------------
# Local-first corpora + models (NEVER COMMIT)
# -------------------------
data_proc/
data_raw/
data_gen/
models/

# Derived DB / indexes (rebuildable)
db/
indexes/

# Runtime outputs (derived)
runs/
reports/
releases/
scratch/
tmp/

# Local fetch artifacts / queues
docs/source_fetch/
docs/corpus_queue.json

# Backups / patch artifacts
*.bak
*.bak.*
*.bak_*
*.BAK
*.BAK*
*.BAD
*.BAD*
*.corrupt_*

# Archives / large local artifacts
*.zip
*.7z
*.rar

# -------------------------
# Config handling
# -------------------------
# Keep only example configs in git; keep real machine configs local.
configs/window_*.toml
!configs/window_*.example.toml
configs/*local*.toml
configs/*private*.toml
configs/*secret*.toml
configs/secrets*.toml
configs/private/

# -------------------------
# Optional: logs
# -------------------------
*.log
logs/

# -------------------------
# CI/demo allowlist (commit only this one canon file)
# -------------------------
!sample_data/data_proc/
!sample_data/data_proc/oe_bede_sample_utf8.jsonl
# local venvs
.venv_clean/

