# -------------------------
# SCRIPTORIUM .gitignore
# -------------------------

# Virtual environments
.venv/
venv/
ENV/
env/

# Python caches / build artifacts
__pycache__/
*.py[cod]
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
dist/
build/
*.egg-info/
src/scriptorium.egg-info/

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
*.tmp

# -------------------------
# Local-first corpora + models (NEVER COMMIT)
# -------------------------
data_proc/
data_raw/
data_gen/
models/

# Derived DB / indexes (rebuildable)
db/
indexes/

# Runtime outputs (derived)
runs/
reports/
releases/
scratch/
tmp/

# Local fetch artifacts / queues
docs/source_fetch/
docs/corpus_queue.json

# Backups / patch artifacts
*.bak
*.bak.*
*.bak_*
*.BAK
*.BAK*
*.BAD
*.BAD*
*.corrupt_*

# Archives / large local artifacts
*.zip
*.7z
*.rar

# -------------------------
# Config handling
# -------------------------
# Keep only example configs in git; keep real machine configs local.
configs/window_*.toml
!configs/window_*.example.toml
configs/*local*.toml
configs/*private*.toml
configs/*secret*.toml
configs/secrets*.toml
configs/private/

# -------------------------
# Optional: logs
# -------------------------
*.log
logs/

# -------------------------
# CI/demo allowlist (commit only this one canon file)
# -------------------------
!sample_data/data_proc/
!sample_data/data_proc/oe_bede_sample_utf8.jsonl
# local venvs
.venv_clean/

# -------------------------
# Safety belt: never commit copyrighted source files or local-only registries
# -------------------------

# Private / local-only registries (BYOT / paid editions)
docs/corpora.private.json
docs/corpora.*.private.json
docs/corpora.*.local.json
docs/corpora.demo*.local.json

# Local-only catalogue outputs (keep public catalogue tracked if you want)
docs/SOURCES_CATALOGUE.local.json
docs/SOURCES_CATALOGUE.local.md
docs/SOURCES_CATALOGUE.private.json
docs/SOURCES_CATALOGUE.private.md

# Local-only provenance (recommended: keep all local-only corpora IDs prefixed with "local_")
docs/provenance/local_*.json
docs/provenance/private_*.json

# Marker debug dumps / extraction traces
*.marker.json
*.marker.*.json

# Common ebook / scanned-book formats (do not commit anywhere)
*.pdf
*.epub
*.mobi
*.azw
*.azw3
*.azw4
*.djvu
*.cbz
*.cbr

# --- local/generated (do not commit) ---
/output/
/manifests/
/reports/
/db/
/data_raw/
/data_proc/

# --- one-off patch artifacts / backups ---
*.OLD
*.prevalidate
*.diff
patch_*.py

