# -------------------------
# SCRIPTORIUM .gitignore
# -------------------------

# Virtual environments
.venv/
venv/
ENV/
env/

# Python caches / build artifacts
__pycache__/
*.py[cod]
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
dist/
build/
*.egg-info/
src/scriptorium.egg-info/

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
*.tmp

# -------------------------
# Local-first corpora + models (NEVER COMMIT)
# -------------------------
data_proc/
data_raw/
data_gen/
models/

# Indexes (derived, rebuildable)
indexes/
# If you ever want to track small example indexes, delete this and add allowlist rules.

# Runtime outputs (derived)
runs/
reports/
releases/
scratch/
tmp/

# Local fetch artifacts / queues
docs/source_fetch/
docs/corpus_queue.json

# Backups / patch artifacts
*.bak
*.bak.*
*.corrupt_*

# Archives / large local artifacts
*.zip
*.7z
*.rar

# -------------------------
# Config handling
# -------------------------
# Keep normal configs tracked for reproducibility.
# Ignore only explicitly-local/private overrides.
configs/*local*.toml
configs/*private*.toml
configs/*secret*.toml
configs/secrets*.toml
configs/private/

# -------------------------
# Optional: logs
# -------------------------
*.log
logs/